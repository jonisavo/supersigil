{
  "name": "@supersigil/vitest",
  "version": "0.1.1",
  "description": "Vitest helper for annotating tests with Supersigil criterion refs",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonisavo/supersigil.git",
    "directory": "packages/vitest"
  },
  "homepage": "https://supersigil.org",
  "bugs": "https://github.com/jonisavo/supersigil/issues",
  "keywords": ["vitest", "testing", "supersigil", "specification", "traceability"],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "node esbuild.mjs && tsc --emitDeclarationOnly --noEmit false --outDir dist",
    "prepack": "pnpm build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vitest": ">=4.1.0"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  }
}
