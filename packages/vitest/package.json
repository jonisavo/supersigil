{
  "name": "@supersigil/vitest",
  "version": "0.0.1",
  "description": "Vitest helper for annotating tests with Supersigil criterion refs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "node esbuild.mjs && tsc --emitDeclarationOnly --noEmit false --outDir dist",
    "prepack": "pnpm build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vitest": ">=4.1.0"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  }
}
