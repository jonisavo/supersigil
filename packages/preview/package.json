{
  "name": "@supersigil/preview",
  "version": "0.1.0",
  "description": "Shared presentation kit for Supersigil spec rendering",
  "type": "module",
  "main": "dist/render.js",
  "exports": {
    ".": {
      "import": "./dist/render.js",
      "types": "./dist/render.d.ts"
    },
    "./styles": "./dist/supersigil-preview.css",
    "./scripts": "./dist/supersigil-preview.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node esbuild.mjs && tsc --emitDeclarationOnly --noEmit false --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}