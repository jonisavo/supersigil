---
// Hero — hero section with astrolabe backdrop
import Astrolabe from './Astrolabe.astro';
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <Astrolabe />

  <div class="hero-content reveal">
    <h1>
      Specs that keep up<br/>
      <em>with your code.</em>
    </h1>
    <p class="hero-sub">
      Keep requirements, evidence, and design intent in your repo:
      versioned, verified, and queryable by your team and your agents.
    </p>
    <div class="hero-actions">
      <a href="/getting-started/" class="btn btn-primary">
        Get started
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M6 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="https://github.com/jonisavo/supersigil" class="btn btn-ghost" target="_blank" rel="noopener">
        <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        GitHub
      </a>
    </div>
    <div class="hero-install reveal" style="--reveal-delay: 0.3s">
      <div class="install-box" id="install-box">
        <span class="install-prompt">$</span>
        <code>cargo install supersigil-cli</code>
        <button class="install-copy" id="copy-btn" aria-label="Copy to clipboard" type="button">
          <svg viewBox="0 0 16 16" width="14" height="14"><rect x="5" y="5" width="9" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
        </button>
      </div>
    </div>
    <div class="hero-proof reveal" style="--reveal-delay: 0.4s">
      <div class="hero-proof-card">
        <strong>CI drift detection</strong>
        <span>Tracked files flag when code changes put a spec back in question.</span>
      </div>
      <div class="hero-proof-card">
        <strong>Agent-ready context</strong>
        <span>Installed skills and JSON output give agents precise scope and verification.</span>
      </div>
      <div class="hero-proof-card">
        <strong>Live spec previews</strong>
        <span>Editor extensions render criteria with verification badges, evidence links, and navigation.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 6rem;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 45% at 47% 45%, rgba(30, 35, 50, 0.5) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(201, 165, 92, 0.035) 0%, transparent 70%),
      radial-gradient(ellipse 35% 40% at 30% 55%, rgba(90, 143, 159, 0.025) 0%, transparent 55%),
      radial-gradient(ellipse 35% 40% at 70% 35%, rgba(90, 143, 159, 0.02) 0%, transparent 55%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--gold);
  }
  .hero-sub {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .hero-install { display: flex; justify-content: center; }
  .hero-proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1.5rem;
    text-align: left;
  }
  .hero-proof-card {
    padding: 1rem 1.1rem;
    background: linear-gradient(180deg, rgba(20, 20, 25, 0.82), rgba(12, 12, 18, 0.9));
    border: 1px solid var(--border);
    border-radius: 12px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.18);
  }
  .hero-proof-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
    color: var(--text);
  }
  .hero-proof-card span {
    display: block;
    color: var(--text-muted);
    font-size: 0.83rem;
    line-height: 1.55;
  }

  /* Light theme overrides */
  :global([data-theme='light']) .hero-glow {
    background:
      radial-gradient(ellipse 50% 42% at 50% 40%, rgba(255, 251, 244, 0.78) 0%, rgba(255, 251, 244, 0) 70%),
      radial-gradient(ellipse 62% 52% at 50% 42%, rgba(138, 108, 47, 0.055) 0%, transparent 72%),
      radial-gradient(ellipse 38% 42% at 28% 58%, rgba(61, 112, 128, 0.04) 0%, transparent 58%),
      radial-gradient(ellipse 38% 42% at 72% 34%, rgba(61, 112, 128, 0.032) 0%, transparent 58%);
  }
  :global([data-theme='light']) .hero {
    background:
      linear-gradient(180deg, #f5efe5 0%, #f0ebe2 55%, #ede8df 100%);
  }
  :global([data-theme='light']) .hero-sub {
    color: #5a5148;
  }
  :global([data-theme='light']) .hero-proof-card {
    background: linear-gradient(180deg, rgba(245, 239, 229, 0.96), rgba(237, 232, 223, 0.94));
    border-color: rgba(42, 37, 32, 0.12);
    box-shadow: 0 18px 38px rgba(138, 108, 47, 0.08);
  }
  :global([data-theme='light']) .hero-proof-card span {
    color: #62584e;
  }

  @media (max-width: 900px) {
    .hero-proof {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Copy install command
  const copyBtn = document.getElementById('copy-btn');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('cargo install supersigil-cli');
      copyBtn.innerHTML = '<svg viewBox="0 0 16 16" width="14" height="14"><path d="M4 8l3 3 5-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      setTimeout(() => {
        copyBtn.innerHTML = '<svg viewBox="0 0 16 16" width="14" height="14"><rect x="5" y="5" width="9" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>';
      }, 2000);
    } catch (e) {
      console.warn('Clipboard API unavailable:', e);
    }
  });
</script>
