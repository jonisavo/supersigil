{
  "name": "supersigil-website",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "cd ../packages/preview && pnpm run build && cd ../../website && cp ../packages/preview/dist/supersigil-preview.css ../packages/preview/dist/render-iife.js ../packages/preview/dist/supersigil-preview.js public/explore/ && supersigil graph --format json > public/explore/graph.json && (supersigil render --format json > public/explore/render-data.json || true)",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "bundle:standalone": "esbuild src/components/explore/graph-explorer.js --bundle --format=iife --global-name=SupersigilExplorer --alias:d3=./src/components/explore/d3-global.cjs --main-fields=module,main --outfile=../crates/supersigil-cli/src/commands/explore_standalone.js"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.3",
    "astro": "^6.1.4",
    "astro-mermaid": "^2.0.1",
    "d3": "^7.9.0",
    "force-in-a-box": "^1.0.2",
    "mermaid": "^11.14.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "catalog:",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.4.0",
    "starlight-llms-txt": "^0.8.0",
    "vitest": "catalog:"
  }
}
