{
  "name": "supersigil-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "supersigil graph --format json > public/explore/graph.json",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "bundle:standalone": "esbuild src/components/explore/graph-explorer.js --bundle --format=iife --global-name=SupersigilExplorer --alias:d3=./src/components/explore/d3-global.cjs --main-fields=module,main --outfile=../crates/supersigil-cli/src/commands/explore_standalone.js"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.0",
    "astro-mermaid": "^1.3.1",
    "d3": "^7.9.0",
    "force-in-a-box": "^1.0.2",
    "mermaid": "^11.13.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "esbuild": "^0.27.4",
    "starlight-llms-txt": "^0.8.0",
    "vitest": "^3.0.0"
  }
}
