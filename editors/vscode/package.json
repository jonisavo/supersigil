{
  "name": "supersigil",
  "packageManager": "pnpm@10.33.0",
  "displayName": "Supersigil",
  "description": "Language Server for Supersigil",
  "version": "0.13.0",
  "publisher": "supersigil",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonisavo/supersigil"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/supersigil.toml",
    "onUri",
    "onWebviewPanel:supersigil.explorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "supersigil.verify",
        "title": "Supersigil: Verify"
      },
      {
        "command": "supersigil.restartServer",
        "title": "Supersigil: Restart Server"
      },
      {
        "command": "supersigil.showStatus",
        "title": "Supersigil: Show Status"
      },
      {
        "command": "supersigil.init",
        "title": "Supersigil: Initialize Project"
      },
      {
        "command": "supersigil.goToCriterion",
        "title": "Supersigil: Go to Criterion"
      },
      {
        "command": "supersigil.findReferences",
        "title": "Supersigil: Find References"
      },
      {
        "command": "supersigil.openExplorer",
        "title": "Supersigil: Open Graph Explorer",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "supersigil.openExplorerAt",
        "title": "Open in Graph Explorer",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "supersigil.openExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "supersigil.openExplorerAt",
          "when": "view == supersigil.specExplorer && viewItem == document",
          "group": "inline"
        }
      ]
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./media/supersigil-preview.css"
    ],
    "markdown.previewScripts": [
      "./media/supersigil-preview.js"
    ],
    "views": {
      "explorer": [
        {
          "id": "supersigil.specExplorer",
          "name": "Supersigil Specifications",
          "icon": "icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "supersigil.specExplorer",
        "contents": "No supersigil project found in this workspace.\n[Initialize Project](command:supersigil.init)",
        "when": "supersigil.noRoots && !supersigil.binaryNotFound"
      },
      {
        "view": "supersigil.specExplorer",
        "contents": "Supersigil LSP server not found.\n\nOn Windows, download the native release zip from GitHub Releases and add its unpacked directory to `PATH`, or set `supersigil.lsp.serverPath`.\n\nOn macOS and Linux, install with Homebrew, your package manager, or `cargo install supersigil-lsp`.\n\n[Installation Guide](https://supersigil.org/guides/editor-setup/)\n[Open Terminal](command:workbench.action.terminal.new)\n[Configure Path](command:workbench.action.openSettings?%5B%22supersigil.lsp.serverPath%22%5D)\n[Retry](command:supersigil.retryBinaryResolution)",
        "when": "supersigil.binaryNotFound"
      }
    ],
    "languages": [
      {
        "id": "supersigil-xml-injection"
      }
    ],
    "grammars": [
      {
        "language": "supersigil-xml-injection",
        "scopeName": "markdown.supersigil-xml.codeblock",
        "path": "./syntaxes/supersigil-xml-injection.json",
        "injectTo": [
          "text.html.markdown",
          "source.mdx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.supersigil-xml": "xml"
        }
      }
    ],
    "configuration": {
      "title": "Supersigil",
      "properties": {
        "supersigil.lsp.serverPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Absolute path to the supersigil-lsp binary. When null, searches $PATH."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "package": "pnpm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.7.1",
    "d3": "^7.9.0",
    "esbuild": "catalog:",
    "force-in-a-box": "^1.0.2",
    "jsdom": "^26.1.0",
    "@supersigil/vitest": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
